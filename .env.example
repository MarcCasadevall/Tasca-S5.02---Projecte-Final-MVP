# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bakery_db
DB_USER=bakery_user
DB_PASSWORD=bakery_pass

# JWT
# Must be at least 32 characters (256 bits) for HMAC-SHA256
# Generate a secure one with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-secure-random-string-minimum-32-characters
JWT_EXPIRATION=86400000

# Server
SERVER_PORT=8080
